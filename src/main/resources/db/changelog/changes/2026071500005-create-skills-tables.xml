<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="2026071500005-create-skills-table" author="thanhITSW">
        <createTable tableName="skills">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="timestamp(6)"/>
            <column name="last_modified_by" type="varchar(50)"/>
            <column name="last_modified_date" type="timestamp(6)"/>
        </createTable>
    </changeSet>

    <changeSet id="2026071500005-create-technician-skills-table" author="thanhITSW">
        <createTable tableName="technician_skills">
            <column name="technician_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="skill_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="technician_skills" columnNames="technician_id,skill_id"
                       constraintName="pk_technician_skills"/>
        <addForeignKeyConstraint baseTableName="technician_skills" baseColumnNames="technician_id"
                                 referencedTableName="technicians" referencedColumnNames="id"
                                 constraintName="fk_technician_skills_technician"/>
        <addForeignKeyConstraint baseTableName="technician_skills" baseColumnNames="skill_id"
                                 referencedTableName="skills" referencedColumnNames="id"
                                 constraintName="fk_technician_skills_skill"/>
    </changeSet>

    <changeSet id="2026071500005-create-service-type-skills-table" author="thanhITSW">
        <createTable tableName="service_type_skills">
            <column name="service_type_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="skill_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="service_type_skills" columnNames="service_type_id,skill_id"
                       constraintName="pk_service_type_skills"/>
        <addForeignKeyConstraint baseTableName="service_type_skills" baseColumnNames="service_type_id"
                                 referencedTableName="service_types" referencedColumnNames="id"
                                 constraintName="fk_service_type_skills_service_type"/>
        <addForeignKeyConstraint baseTableName="service_type_skills" baseColumnNames="skill_id"
                                 referencedTableName="skills" referencedColumnNames="id"
                                 constraintName="fk_service_type_skills_skill"/>
    </changeSet>

</databaseChangeLog>
